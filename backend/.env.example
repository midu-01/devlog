# Copy to .env and fill in real values. Never commit .env.

# PostgreSQL connection
DATABASE_URL=postgresql://devlog:devlog@localhost:5432/devlog

# JWT — generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-64-char-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS — JSON list format (pydantic-settings parses it)
CORS_ORIGINS=["http://localhost:5173"]

# AI / LangChain — provider swap is a one-line change here
# groq (free tier: https://console.groq.com) | openai | anthropic
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=gsk_your_key_here
